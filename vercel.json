{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{dist/**,node_modules/@simplewebauthn/browser/**}",
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
